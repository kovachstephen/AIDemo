@page "/whiskeys"
@model WhiskeysModel
@{
    ViewData["Title"] = "Whiskey Collection";
}

<div class="container mt-5">
    <h1 class="mb-4 text-center">Whiskey Collection</h1>
    <div class="mb-4 d-flex flex-wrap gap-2">
        <a href="/" class="btn btn-outline-primary">Back to Home</a>
        <a href="/cocktails" class="btn btn-primary">View Cocktails</a>
        <a href="/whiskey/edit" class="btn btn-success">Add New Whiskey</a>
    </div>
    <input type="text" id="search" class="form-control mb-4" placeholder="Search by type, brand, or mash bill..." onkeyup="filterTable()">
    <div class="table-responsive">
        <table id="whiskeyTable" class="table table-hover">
            <thead>
                <tr><th>Type</th><th>Brand</th><th>Mash Bill</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var w in Model.Whiskeys)
                {
                    <tr>
                        <td><a href="/cocktails?spirit=@w.Type.ToLower()" class="btn btn-link">@w.Type</a></td>
                        <td><a href="/brand?b=@w.Brand.ToLower().Replace(" ", "-").Replace("'", "")" class="btn btn-link">@w.Brand</a></td>
                        <td>@w.MashBill</td>
                        <td>
                            <a href="/whiskey/edit/@w.Brand.ToLower().Replace(" ", "-").Replace("'", "")" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-brand="@w.Brand" data-type="@w.Type">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this whiskey record?</p>
                <p><strong>Whiskey:</strong> <span id="deleteWhiskeyName"></span></p>
                <p class="text-danger">This will also delete the related brand details.</p>
            </div>
            <div class="modal-footer">
                <form method="post" asp-page-handler="Delete">
                    <input type="hidden" id="deleteBrand" name="brand" value="">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function filterTable() {
        var input = document.getElementById('search');
        var filter = input.value.toLowerCase();
        var table = document.getElementById('whiskeyTable');
        var rows = table.getElementsByTagName('tr');
        for (var i = 1; i < rows.length; i++) {
            var text = rows[i].textContent.toLowerCase();
            rows[i].style.display = text.includes(filter) ? '' : 'none';
        }
    }
    
    var deleteModal = document.getElementById('deleteModal');
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var brand = button.getAttribute('data-brand');
        var type = button.getAttribute('data-type');
        document.getElementById('deleteWhiskeyName').textContent = type + ' - ' + brand;
        document.getElementById('deleteBrand').value = brand.toLowerCase().replace(/ /g, '-').replace(/'/g, '');
    });
</script>
