@page "/whiskey/edit/{brand?}"
@model WhiskeyEditModel
@{
    ViewData["Title"] = Model.IsNew ? "Add Whiskey" : "Edit Whiskey";
}

<div class="container mt-5">
    <h1 class="mb-4 text-center">@(Model.IsNew ? "Add New Whiskey" : "Edit Whiskey")</h1>
    
    <div class="mb-4">
        <a href="/whiskeys" class="btn btn-outline-primary">Back to Whiskeys</a>
    </div>

    <form method="post">
        <div class="row">
            <div class="col-md-6 mx-auto">
                <div class="mb-3">
                    <label for="type" class="form-label">Type</label>
                    <select id="type" name="Type" class="form-select" required>
                        <option value="">Select Type...</option>
                        <option value="Bourbon" selected="@(Model.Whiskey.Type == "Bourbon")">Bourbon</option>
                        <option value="Rye" selected="@(Model.Whiskey.Type == "Rye")">Rye</option>
                        <option value="Scotch" selected="@(Model.Whiskey.Type == "Scotch")">Scotch</option>
                        <option value="Irish Whiskey" selected="@(Model.Whiskey.Type == "Irish Whiskey")">Irish Whiskey</option>
                        <option value="Tennessee" selected="@(Model.Whiskey.Type == "Tennessee")">Tennessee</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="brand" class="form-label">Brand</label>
                    <input type="text" id="brand" name="Brand" class="form-control" 
                           value="@Model.Whiskey.Brand" required>
                </div>

                <div class="mb-3">
                    <label for="mashBill" class="form-label">Mash Bill</label>
                    <input type="text" id="mashBill" name="MashBill" class="form-control" 
                           value="@Model.Whiskey.MashBill" placeholder="e.g., Corn (75%), rye (13%), barley (12%)">
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Image URL</label>
                    <input type="url" id="image" name="Image" class="form-control" 
                           value="@Model.Whiskey.Image" placeholder="https://...">
                    @if (!string.IsNullOrEmpty(Model.Whiskey.Image))
                    {
                        <img src="@Model.Whiskey.Image" class="mt-2" style="max-height: 150px; border: 2px solid var(--color-cognac);" alt="Whiskey preview">
                    }
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
    </form>
</div>
