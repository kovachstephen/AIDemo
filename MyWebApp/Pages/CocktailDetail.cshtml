@page "/cocktail/{name}"
@model CocktailDetailModel
@{
    ViewData["Title"] = Model.Cocktail?.Name ?? "Cocktail";
}

<div class="container mt-5">
    <h1 class="mb-4 text-center">@Model.Cocktail?.Name</h1>
    <div class="mb-4">
        <a href="/cocktails" class="btn btn-outline-primary">Back to Cocktails</a>
    </div>
    @if (Model.Cocktail != null)
    {
        <div class="row mb-4">
            <div class="col-md-6 mx-auto">
                <img src="@Model.Cocktail.Image" class="img-fluid rounded" alt="@Model.Cocktail.Name" style="border: 3px solid var(--color-cognac);">
            </div>
        </div>
        <h3 class="mb-3">Ingredients</h3>
        <div class="table-responsive mb-4">
            <table class="table table-striped">
                <thead>
                    <tr><th>Name</th><th>Volume</th><th>Preferred Brand</th></tr>
                </thead>
                <tbody>
                    @foreach (var i in Model.Cocktail.Ingredients ?? new List<Ingredient>())
                    {
                        <tr><td>@i.Name</td><td>@i.Volume</td><td>@i.PreferredBrand</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <h3 class="mb-3">Recipe</h3>
        <div class="card">
            <div class="card-body">
                <p class="lead">@(Model.Cocktail?.Recipe ?? "Mix ingredients according to taste preferences.")</p>
            </div>
        </div>
    }
    else
    {
        <p class="text-center">Cocktail not found.</p>
    }
</div>
