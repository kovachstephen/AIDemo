@page "/"
@{
    ViewData["Title"] = "Whiskey & Cocktails";
}

<style>
    .hero-section {
        background: linear-gradient(rgba(26, 20, 16, 0.85), rgba(26, 20, 16, 0.85)), url('https://www.goodfreephotos.com/united-states/kentucky/other-kentucky/barrels-of-whiskey-in-the-cellar-at-buffalo-trace-distillery-kentucky.jpg');
        background-size: cover;
        background-position: center;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .lounge-card {
        background: linear-gradient(135deg, var(--color-medium-brown), var(--color-dark-brown));
        border: 2px solid var(--color-cognac);
        border-radius: 12px;
    }
    
    .whiskey-btn {
        background: transparent;
        border: 2px solid var(--color-gold);
        color: var(--color-gold);
        font-family: 'Playfair Display', serif;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: all 0.3s ease;
    }
    
    .whiskey-btn:hover {
        background: var(--color-gold);
        color: var(--color-dark-brown);
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(201, 162, 39, 0.3);
    }
</style>

<div class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 mb-4">The Grand Whiskey Lounge</h1>
        <p class="lead mb-5">Discover exceptional whiskeys & craft the perfect cocktail</p>
        
        <div class="card lounge-card p-4 mx-auto" style="max-width: 500px;">
            <h4 class="mb-3" style="color: var(--color-gold);">What whiskey do you have?</h4>
            <p class="small mb-3" style="color: var(--color-cream); opacity: 0.8;">Enter your whiskey type to find cocktails you can make</p>
            <form method="get" action="/cocktails">
                <div class="input-group">
                    <input type="text" 
                           name="spirit" 
                           class="form-control" 
                           placeholder="e.g., Bourbon, Rye, Scotch..." 
                           required>
                    <button type="submit" class="btn btn-primary">Find Cocktails</button>
                </div>
            </form>
        </div>

        <div class="d-flex gap-3 justify-content-center mt-5">
            <a href="/whiskeys" class="btn btn-lg whiskey-btn">Whiskey Collection</a>
            <a href="/cocktails" class="btn btn-lg btn-primary">View All Cocktails</a>
        </div>
    </div>
</div>
