@page "/cocktails"
@model CocktailsModel
@{
    ViewData["Title"] = "Cocktails";
}

<div class="container mt-5">
    <h1 class="mb-4 text-center">Cocktails</h1>
    <div class="mb-4 d-flex flex-wrap gap-2">
        <a href="/" class="btn btn-outline-primary">Back to Home</a>
        @if (!string.IsNullOrEmpty(Model.Spirit))
        {
            <a href="/cocktails" class="btn btn-secondary">Show all cocktails</a>
        }
    </div>
    @if (Model.Cocktails.Count == 0 && !string.IsNullOrEmpty(Model.Spirit))
    {
        <div class="alert alert-warning">
            <strong>No cocktails found for "@Model.Spirit".</strong>
            <p class="mb-0">Try a different whiskey type like Bourbon, Rye, Scotch, or Irish Whiskey.</p>
        </div>
    }
    @if (Model.Cocktails.Count > 0)
    {
        <input type="text" id="search" class="form-control mb-4" placeholder="Search..." onkeyup="filterTable()">
        <div class="table-responsive">
            <table id="cocktailTable" class="table table-hover">
                <thead>
                    <tr><th>Name</th><th>Base Spirit</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Cocktails)
                    {
                        <tr>
                            <td><a href="/cocktail/@c.Name.ToLower().Replace(" ", "-")" class="btn btn-link">@c.Name</a></td>
                            <td>@c.BaseSpirit</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.Cocktails.Count > 0)
{
    <script>
        function filterTable() {
            var input = document.getElementById('search');
            var filter = input.value.toLowerCase();
            var table = document.getElementById('cocktailTable');
            var rows = table.getElementsByTagName('tr');
            for (var i = 1; i < rows.length; i++) {
                var text = rows[i].textContent.toLowerCase();
                rows[i].style.display = text.includes(filter) ? '' : 'none';
            }
        }
    </script>
}
